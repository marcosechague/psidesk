# ─────────────────────────────────────────────────────────────
# Infra de desarrollo (raíz) — consumido por docker-compose.yml
# Copiar a .env y ajustar si hace falta:   cp .env.example .env
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=psicopy
POSTGRES_PASSWORD=psicopy
POSTGRES_DB=psicopy
POSTGRES_PORT=5350

# La connection string que usa la APP vive en app/.env (ver app/.env.example).
# Con el docker-compose de arriba, en dev sería:
#   DATABASE_URL="postgresql://psicopy:psicopy@localhost:5350/psicopy?schema=public"
